{
  "name": "pss_gui_utility",
  "version": "1.0.0",
  "description": "Vue 3 + Electron + Go Desktop Application",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "cross-env NODE_ENV=development electron .",
    "build": "vite build",
    "start": "npm run build && cross-env NODE_ENV=production electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "keywords": [
    "electron",
    "vue3",
    "go",
    "desktop"
  ],
  "author": {
    "name": "Franco",
    "email": "franco@example.com"
  },
  "homepage": "https://github.com/franco/pss_gui_utility",
  "license": "ISC",
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^34.0.0",
    "electron-builder": "^26.8.1",
    "vite": "^8.0.0",
    "vue": "^3.5.30"
  },
  "build": {
    "appId": "com.pss.gui.utility",
    "productName": "PSS GUI Utility",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "build/pss-gui-utility.desktop"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ]
    }
  },
  "dependencies": {
    "mssql": "^12.5.5",
    "mysql2": "^3.22.4",
    "pinia": "^3.0.4",
    "view-ui-plus": "^1.3.24",
    "vue-router": "^4.6.4"
  }
}
